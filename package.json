{
	"name": "mahira-laundry",
	"version": "1.0.0",
	"private": true,
	"packageManager": "npm@11.13.0",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "cd apps/web && npm run dev",
		"build": "cd apps/web && npm run build",
		"lint": "npx @biomejs/biome check --write .",
		"db:generate": "cd apps/web && npm run db:generate",
		"db:migrate": "cd apps/web && npm run db:migrate",
		"db:push": "cd apps/web && npm run db:push",
		"db:studio": "cd apps/web && npm run db:studio"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"turbo": "^2.9.6",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"html2canvas": "^1.4.1",
		"html5-qrcode": "^2.3.8",
		"jspdf": "^4.2.1",
		"next": "^16.2.4",
		"qrcode.react": "^4.2.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5"
	}
}

{
	"$schema": "https://turbo.build/schema.json",
	"globalDependencies": [".env"],
	"globalEnv": [
		"NEXT_PUBLIC_APP_NAME",
		"NEXT_PUBLIC_APP_URL",
		"NEXT_PUBLIC_WHATSAPP_CS",
		"NEXT_PUBLIC_SUPABASE_URL",
		"NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
		"NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION",
		"NODE_ENV"
	],
	"globalPassThroughEnv": [
		"SUPABASE_DB_URL",
		"MIDTRANS_SERVER_KEY",
		"MIDTRANS_IS_PRODUCTION",
		"FONNTE_API_KEY",
		"RESEND_API_KEY",
		"RESEND_FROM_EMAIL",
		"RESEND_FROM_NAME"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**", "!.next/cache/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"db:generate": {},
		"db:migrate": {},
		"db:push": {}
	}
}

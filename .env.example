# ─────────────────────────────────────────────
# .env.example — Mahira Laundry Jakarta Salemba
# ─────────────────────────────────────────────

# App identity
NEXT_PUBLIC_APP_NAME="Mahira Laundry"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BRAND_PRIMARY=#1a6b4a
NEXT_PUBLIC_BRAND_ACCENT=#d4a017
NEXT_PUBLIC_LOCATION="Salemba, Jakarta Pusat"
NEXT_PUBLIC_WHATSAPP_CS=628xxxxxxxxxx

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_DB_URL=postgresql://postgres:...

# Payment — Midtrans Indonesia
MIDTRANS_SERVER_KEY=Mid-server-...
MIDTRANS_CLIENT_KEY=Mid-client-...
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=Mid-client-...
MIDTRANS_IS_PRODUCTION=false

# Notifikasi
FONNTE_API_KEY=xxx
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@mahiralaundry.id
RESEND_FROM_NAME="Mahira Laundry"

# Redis — Upstash (rate limit, cache, queue)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Google Maps — Jakarta area
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIza...
NEXT_PUBLIC_MAP_CENTER_LAT=-6.2115
NEXT_PUBLIC_MAP_CENTER_LNG=106.8559
NEXT_PUBLIC_MAP_DEFAULT_ZOOM=14

# Logistik
BITESHIP_API_KEY=xxx
RAJA_ONGKIR_API_KEY=xxx

# Monitoring
SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_ORG=mahira-laundry
SENTRY_PROJECT=web
AXIOM_DATASET=mahira-prod
AXIOM_TOKEN=xxx

# Auth (opsional: OAuth)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx

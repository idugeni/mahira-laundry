# Dependencies
node_modules/
.pnp
.pnp.*
yarn-error.log*
.pnpm-debug.log*

# Next.js
.next/
out/
next-env.d.ts

# Production & Builds
dist/
build/
*.tsbuildinfo

# Environment Variables (CRITICAL)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
#.env.example (deleted)

# Tools & Frameworks
.turbo/
.vercel
.agents/
.gemini/
.claude/
.kiro/
.trae/
.windsurf/
.sentry-debug-log
skills-lock.json

# Testing
coverage/
apps/web/__tests__/
apps/web/vitest.config.ts
apps/web/vitest.setup.ts

# IDEs & System
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*

# Database & Migrations (STRICT)
supabase/.temp/
supabase/functions/.env
supabase/migrations/
supabase/seed.sql
.supabase/
apps/web/drizzle/
apps/web/migrate-db.ts
apps/web/test-db.ts
drizzle/

# Certificates & Keys (CRITICAL — never commit)
*.pem
*.crt
*.key
*.cert
*.p12
*.pfx
*.cer
*.der
*.csr
localhost.pem
localhost-key.pem
apps/web/.next/certificates/
apps/web/certificates/
trash/
scratch/
apps/web/scratch/
apps/web/lint_errors.txt
apps/web/pos_errors.txt
apps/web/test-query.mjs